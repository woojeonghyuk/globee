{
  "expo": {
    "name": "Globee",
    "slug": "globee",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/globee-app-icon.png",
    "scheme": "globee",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/45cf3c36-b120-4d14-aa60-a42b31d10bf4"
    },
    "ios": {
      "bundleIdentifier": "com.globee.parent",
      "buildNumber": "1",
      "supportsTablet": false
    },
    "android": {
      "package": "com.globee.parent",
      "versionCode": 1,
      "permissions": [],
      "adaptiveIcon": {
        "backgroundColor": "#FFF498",
        "foregroundImage": "./assets/images/globee-app-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/globee-app-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-media-library",
        {
          "photosPermission": "Globee가 완료문화 사진을 갤러리에 저장하기 위해 사진 접근 권한을 사용합니다.",
          "savePhotosPermission": "Globee가 완료문화 사진을 갤러리에 저장하기 위해 사진 저장 권한을 사용합니다.",
          "granularPermissions": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/globee-app-icon.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#FFF498",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "45cf3c36-b120-4d14-aa60-a42b31d10bf4"
      }
    },
    "owner": "woojeonghyuk"
  }
}
